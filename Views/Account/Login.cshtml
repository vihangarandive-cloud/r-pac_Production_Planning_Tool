@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | r-pac Production Planner</title>
    <link rel="icon" type="image/png" href="@Url.Content("~/Content/images/logo.png")">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --rpac-blue: #0f172a;
            --rpac-blue-light: #1e293b;
            --rpac-red: #e11d48;
            --rpac-red-hover: #be123c;
            --text-main: #1e293b;
            --text-muted: #64748b;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at top right, #1e3a8a, #0f172a);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow: hidden;
        }

        .login-card {
            width: 100%;
            max-width: 520px;
            border: none;
            border-radius: 2.5rem;
            padding: 3rem 3rem;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(25px);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
            transform: translateY(0);
            transition: all 0.3s ease;
        }

        .login-card:hover {
            transform: translateY(-5px);
        }

        .form-label {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
            margin-bottom: 0.75rem;
            display: block;
        }

        .form-control {
            background-color: #f8fafc;
            border: 2px solid #e2e8f0;
            border-radius: 1.25rem;
            padding: 1rem 1.25rem;
            font-weight: 500;
            color: var(--text-main);
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .form-control:focus {
            background-color: white;
            border-color: var(--rpac-red);
            box-shadow: 0 0 0 4px rgba(225, 29, 72, 0.1);
            outline: none;
        }

        .btn-authenticate {
            background-color: var(--rpac-red);
            color: white;
            border: none;
            border-radius: 1.25rem;
            padding: 1.1rem;
            font-weight: 800;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            box-shadow: 0 10px 15px -3px rgba(225, 29, 72, 0.4);
            transition: all 0.3s ease;
            width: 100%;
            margin-top: 3rem;
        }

        .btn-authenticate:hover {
            background-color: var(--rpac-red-hover);
            transform: translateY(-2px);
            box-shadow: 0 20px 25px -5px rgba(225, 29, 72, 0.4);
            color: white;
        }

        .btn-authenticate:active {
            transform: translateY(0);
        }

        .logo-text {
            font-size: 1.25rem;
            font-weight: 900;
            letter-spacing: -0.02em;
            color: var(--text-main);
            margin-bottom: 0.25rem;
        }

        .sub-header {
            font-size: 1.75rem;
            font-weight: 900;
            letter-spacing: -0.04em;
            color: #0f172a;
            margin-bottom: 0.5rem;
            line-height: 1.1;
        }

        .tagline {
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
            margin-bottom: 2rem;
        }

        .alert {
            border-radius: 1.25rem;
            font-size: 0.8rem;
            font-weight: 600;
            border: none;
        }
    </style>
</head>

<body>
    <div class="login-card">
        <div class="text-center">
            <img src="@Url.Content("~/Content/images/logo.png")" alt="RPAC Logo"
                style="height: 90px; margin-bottom: 1.5rem;" />
            <h1 class="sub-header">PRODUCTION PLANNING TOOL</h1>
            <p class="tagline">r-pac Printcare Lanka</p>
        </div>
        @if (ViewBag.Error != null)



        {
            <div class="alert alert-danger mb-4">
                @ViewBag.Error
            </div>
        }
        @using (Html.BeginForm("Login", "Account", FormMethod.Post))



        {
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="form-label">Username</label>
                <input type="text" name="username" class="form-control" placeholder="Unique User ID" required autofocus
                    autocomplete="off" />
            </div>
            <div class="mb-4">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" placeholder="Required" required />
            </div>
            <button type="submit" class="btn btn-authenticate d-flex justify-content-center align-items-center gap-2">
                Log In
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                    class="lucide lucide-log-in">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                    <polyline points="10 17 15 12 10 7" />
                    <line x1="15" x2="3" y1="12" y2="12" />
                </svg>
            </button>
        }

    </div>
</body>

</html>
