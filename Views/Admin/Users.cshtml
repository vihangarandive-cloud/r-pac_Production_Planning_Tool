@model IEnumerable<RPACProductionPlanner.Models.UserAccount>
@{
    ViewBag.Title = "Security & Access Control";
}

<div class="animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-black mb-1 text-slate-900 tracking-tight">User Management</h1>
            <p class="text-muted x-small mb-0 fw-semibold uppercase tracking-widest">System Users | Access Rights</p>
        </div>
        <button class="btn btn-rpac-red text-black x-small fw-black text-uppercase tracking-widest px-4 py-2 rounded-3 shadow-sm hover-shadow transition-all" data-bs-toggle="modal" data-bs-target="#addUserModal">
            <i class="bi bi-person-plus-fill me-2"></i> Add New User
        </button>
    </div>
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4 animate-shake">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
                <div class="card-header bg-white border-0 p-4">
                    <h5 class="mb-0 fw-bold text-dark">Active System Identities</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr class="text-xxs fw-black text-uppercase tracking-widest text-muted border-bottom">
                                <th class="ps-4 py-3">Identity</th>
                                <th class="py-3">Role</th>
                                <th class="py-3">Current Status</th>
                                <th class="py-3 text-end pe-4">Controls</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null) {
                                foreach (var user in Model) {
                                    <tr class="border-bottom">
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                <div class="bg-slate-100 rounded-circle p-2 me-3 text-slate-400">
                                                    <i class="bi bi-person-circle fs-5"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-black text-slate-900 small">@user.FullName</div>
                                                    <div class="text-xxs text-muted fw-bold">@user.Username</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge-role badge-admin">
                                                @user.RoleName
                                            </span>
                                        </td>
                                        <td>
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" @(user.IsActive ? "checked" : "") onclick="toggleUserStatus('@user.Username')">
                                                <span class="x-small fw-bold @(user.IsActive ? "text-success" : "text-muted") ms-2">@(user.IsActive ? "ACTIVE" : "DISABLED")</span>
                                            </div>
                                        </td>
                                        <td class="text-end pe-4">
                                            <button onclick="resetPassword('@user.Username')" class="btn btn-light btn-sm border-0 rounded-3 hover-shadow me-1">
                                                <i class="bi bi-key-fill text-muted"></i>
                                            </button>
                                             <button onclick="editUser('@user.FullName', '@user.Username', '@user.RoleName')" class="btn btn-light btn-sm border-0 rounded-3 hover-shadow" data-bs-toggle="modal" data-bs-target="#editUserModal">
                                                 <i class="bi bi-pencil-square text-muted"></i>
                                             </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white mb-4">
                <div class="card-header bg-slate-900 text-black text-bold border-0 p-4">
                    <h6 class="mb-0 fw-black text-uppercase tracking-widest small">Privilege Levels</h6>
                </div>
                <div class="list-group list-group-flush">
                    <div class="list-group-item p-4 border-0 border-bottom">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-black text-slate-900 small text-uppercase">Management</span>
                            <span class="badge bg-danger bg-opacity-10 text-danger x-small fw-black">Level 5</span>
                        </div>
                        <p class="text-muted x-small mb-0 fw-semibold">Full administrative access, user management, and system configuration.</p>
                    </div>
                    <div class="list-group-item p-4 border-0 border-bottom">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-black text-slate-900 small text-uppercase">Production Planner</span>
                            <span class="badge bg-primary bg-opacity-10 text-primary x-small fw-black">Level 3</span>
                        </div>
                        <p class="text-muted x-small mb-0 fw-semibold">Gantt scheduling, work order priority, and machine allocation.</p>
                    </div>
                    <div class="list-group-item p-4 border-0">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-black text-slate-900 small text-uppercase">Shift Executive</span>
                            <span class="badge bg-success bg-opacity-10 text-success x-small fw-black">Level 1</span>
                        </div>
                        <p class="text-muted x-small mb-0 fw-semibold">Real-time status updates and shift monitoring.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Modals {
    <div class="modal fade" id="addUserModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-5 overflow-hidden">
                <div class="modal-header bg-slate-900 text-black border-0 p-4">
                    <h5 class="fw-black mb-0 tracking-tight">New User Registration</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="@Url.Action("AddUser", "Admin")" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body p-4 bg-light bg-opacity-50">
                        <div class="mb-4">
                            <label class="text-xxs fw-black uppercase tracking-widest text-muted mb-2 d-block">Full Name</label>
                            <input type="text" name="FullName" class="form-control border-0 shadow-sm fw-bold p-3" placeholder="e.g. Suraj Lakshan" required />
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="text-xxs fw-black uppercase tracking-widest text-muted mb-2 d-block">Username</label>
                                <input type="text" name="Username" class="form-control border-0 shadow-sm fw-bold p-3" placeholder="suraj.l" required />
                            </div>
                            <div class="col-md-6">
                                <label class="text-xxs fw-black uppercase tracking-widest text-muted mb-2 d-block">Role</label>
                                <select name="Role" class="form-select border-0 shadow-sm fw-bold p-3" required>
                                    <option value="Planner">Production Planner</option>
                                    <option value="ShiftExecutive">Shift Executive</option>
                                    <option value="Manager">Manager</option>
                                    </select>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="text-xxs fw-black uppercase tracking-widest text-muted mb-2 d-block">Initial Credentials</label>
                            <input type="password" name="Password" class="form-control border-0 shadow-sm fw-bold p-3" placeholder="Enter a password" required />
                        </div>
                        <div class="alert alert-warning border-0 rounded-4 x-small fw-bold">
                            <i class="bi bi-shield-lock-fill me-2"></i> Ensure credentials adhere to corporate security policies.
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4 pt-0 bg-light bg-opacity-50">
                        <button type="button" class="btn btn-link text-muted x-small fw-black text-uppercase tracking-widest text-decoration-none" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-rpac-red text-black rounded-3 px-4 x-small fw-black text-uppercase tracking-widest shadow-sm">Create User</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit User Modal -->
    <div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-5 overflow-hidden">
                <div class="modal-header bg-slate-900 text-black border-0 p-4">
                    <h5 class="fw-black mb-0 tracking-tight">Modify User Details</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="@Url.Action("EditUser", "Admin")" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body p-4 bg-light bg-opacity-50">
                        <div class="mb-4">
                            <label class="text-xxs fw-black uppercase tracking-widest text-muted mb-2 d-block">Full Name</label>
                            <input type="text" name="FullName" id="editFullName" class="form-control border-0 shadow-sm fw-bold p-3" required />
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="text-xxs fw-black uppercase tracking-widest text-muted mb-2 d-block">Username</label>
                                <input type="text" name="Username" id="editUsername" class="form-control border-0 shadow-sm fw-bold p-3 bg-white" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="text-xxs fw-black uppercase tracking-widest text-muted mb-2 d-block">Role</label>
                                <select name="Role" id="editRole" class="form-select border-0 shadow-sm fw-bold p-3" required>
                                    <option value="Planner">Production Planner</option>
                                    <option value="ShiftExecutive">Shift Executive</option>
                                    <option value="Manager">Manager</option>
                                </select>
                            </div>
                        </div>
                        <div class="alert alert-info border-0 rounded-4 x-small fw-bold">
                            <i class="bi bi-info-circle-fill me-2"></i> Username cannot be changed after registration.
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4 pt-0 bg-light bg-opacity-50">
                        <button type="button" class="btn btn-link text-muted x-small fw-black text-uppercase tracking-widest text-decoration-none" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-slate-900 text-black rounded-3 px-4 x-small fw-black text-uppercase tracking-widest shadow-sm">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section scripts {
    <script>
        function toggleUserStatus(username) {
            $.post('@Url.Action("ToggleStatus", "Admin")', { 
                username: username,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            })
            .done(function (res) {
                if (res.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Status Updated',
                        text: 'Identity access permissions have been modified.',
                        timer: 1000,
                        showConfirmButton: false
                    }).then(() => {
                        location.reload();
                    });
                }
            });
        }

        function editUser(fullName, username, roleName) {
            $('#editFullName').val(fullName);
            $('#editUsername').val(username);
            
            // Map RoleName back to option value
            let roleVal = "Manager";
            let lowerRole = roleName.toLowerCase();
            if(lowerRole.includes("admin") || lowerRole.includes("management")) roleVal = "Admin";
            else if(lowerRole.includes("planner")) roleVal = "Planner";
            else if(lowerRole.includes("shift") || lowerRole.includes("executive") || lowerRole.includes("supervisor")) roleVal = "ShiftExecutive";
            
            $('#editRole').val(roleVal);
        }

        function resetPassword(username) {
            Swal.fire({
                title: 'Reset Credentials?',
                text: "A system-generated password will be sent to " + username,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e11d48',
                confirmButtonText: 'Yes, Reset Now'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire('Identity Authenticated', 'Credentials have been reset successfully.', 'success');
                }
            })
        }
    </script>
    <style>
        .form-switch .form-check-input { width: 3em; height: 1.5em; cursor: pointer; }
        .form-switch .form-check-input:checked { background-color: #10b981; border-color: #10b981; }
    </style>
}
