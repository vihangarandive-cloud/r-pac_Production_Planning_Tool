@model IEnumerable<RPACProductionPlanner.Models.BillOfMaterial>
@{
    ViewBag.Title = "Bill of Materials";
}
<div class="animate-fade-in">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-4">
            <li class="breadcrumb-item"><a href="@Url.Action("Index")">Master Data</a></li>
            <li class="breadcrumb-item active">Bill of Materials</li>
        </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-black text-slate-900 text-uppercase tracking-tight mb-0">Production BOM</h1>
        <button class="btn btn-rpac-red text-white x-small fw-black text-uppercase tracking-widest rounded-3 px-4"
            data-bs-toggle="modal" data-bs-target="#addBOMModal">
            <i class="bi bi-plus-lg me-2"></i> Define New BOM
        </button>
    </div>

    <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-xxs fw-black text-uppercase tracking-widest text-muted border-bottom">
                        <th class="ps-4 py-3">Product Name</th>
                        <th class="py-3">Material Component</th>
                        <th class="py-3 text-center">Required Qty</th>
                        <th class="py-3">UOM</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())

                    {
                        <tr>
                            <td colspan="5" class="py-5 text-center text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
                                No BOM definitions found. Start by defining material requirements for products.
                            </td>
                        </tr>
                    }
                    @foreach (var bom in Model)

                    {
                        <tr class="border-bottom">
                            <td class="ps-4">
                                <div class="fw-black text-slate-800">@bom.ProductName</div>
                            </td>
                            <td>
                                <div class="x-small fw-bold text-muted uppercase tracking-widest">Item ID: @bom.ItemId</div>
                            </td>
                            <td class="text-center fw-black text-slate-700">@bom.QuantityRequired.ToString("N2")</td>
                            <td>
                                <span
                                    class="badge bg-slate-100 text-slate-600 border border-slate-200 x-small fw-bold text-black px-2 py-1">@bom.UnitOfMeasure</span>
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-light btn-sm rounded-3" data-bs-toggle="modal" data-bs-target="#editBOMModal" onclick="openEditBOMModal('@bom.ProductName', '@bom.ItemId', '@bom.QuantityRequired', '@bom.UnitOfMeasure')"><i class="bi bi-pencil-fill text-muted"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Modals {
<!-- Add BOM Modal -->
<div class="modal fade" id="addBOMModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-bottom-0 p-4 pb-0">
                <h5 class="modal-title fw-black tracking-tight">Define New BOM</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="@Url.Action("AddBOM", "MasterData")" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Product
                            Name</label>
                        <input type="text" name="ProductName" class="form-control form-control-sm rounded-3"
                            placeholder="e.g., FG_THERMAL_LABEL" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Material Item
                            ID</label>
                        <input type="number" name="ItemId" class="form-control form-control-sm rounded-3"
                            placeholder="e.g., 1" required />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Quantity
                                Required</label>
                            <input type="number" step="0.01" name="QuantityRequired"
                                class="form-control form-control-sm rounded-3" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Unit of
                                Measure</label>
                            <select name="UnitOfMeasure" class="form-select form-select-sm rounded-3" required>
                                <option value="PCS">PCS</option>
                                <option value="SQM">SQM</option>
                                <option value="Liters">Liters</option>
                                <option value="KG">KG</option>
                                <option value="Meters">Meters</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 p-4 pt-0">
                    <button type="button"
                        class="btn btn-light rounded-3 px-4 x-small fw-black text-uppercase tracking-widest"
                        data-bs-dismiss="modal">Cancel</button>
                    <button type="submit"
                        class="btn btn-rpac-red text-white rounded-3 px-4 x-small fw-black text-uppercase tracking-widest">Save
                        BOM</button>
                </div>
        </div>
    </div>
</div>

<!-- Edit BOM Modal -->
<div class="modal fade" id="editBOMModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-bottom-0 p-4 pb-0">
                <h5 class="modal-title fw-black tracking-tight">Edit BOM</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="@Url.Action("BOM", "MasterData")" method="get">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Product Name</label>
                        <input type="text" id="editProductName" class="form-control form-control-sm rounded-3" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Material Item ID</label>
                        <input type="text" id="editItemId" class="form-control form-control-sm rounded-3" readonly />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Quantity Required</label>
                            <input type="number" id="editQuantityRequired" class="form-control form-control-sm rounded-3" readonly />
                        </div>
                        <div class="col-6">
                            <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Unit of Measure</label>
                            <input type="text" id="editUnitOfMeasure" class="form-control form-control-sm rounded-3" readonly />
                        </div>
                    </div>
                    <div class="alert alert-warning x-small mb-0 rounded-3 border-0">
                        <i class="bi bi-info-circle me-1"></i> Edit functionality is disabled for this demo user role.
                    </div>
                </div>
                <div class="modal-footer border-top-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-3 px-4 x-small fw-black text-uppercase tracking-widest" data-bs-dismiss="modal">Close</button>
                </div>
            </form>
        </div>
    </div>
</div>
}

<script>
    function openEditBOMModal(productName, itemId, quantity, uom) {
        document.getElementById('editProductName').value = productName;
        document.getElementById('editItemId').value = itemId;
        document.getElementById('editQuantityRequired').value = quantity;
        document.getElementById('editUnitOfMeasure').value = uom;
    }
</script>
