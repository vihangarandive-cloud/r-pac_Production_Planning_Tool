@model IEnumerable<RPACProductionPlanner.Models.MachineResource>
@{
    ViewBag.Title = "Machine Resources";
}
<div class="animate-fade-in">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-4">
            <li class="breadcrumb-item"><a href="@Url.Action("Index")">Master Data</a></li>
            <li class="breadcrumb-item active">Machines</li>
        </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-black text-slate-900 text-uppercase tracking-tight mb-0">Machine Resources</h1>
        <button class="btn btn-rpac-red text-white x-small fw-black text-uppercase tracking-widest rounded-3 px-4" data-bs-toggle="modal" data-bs-target="#addMachineModal">
            <i class="bi bi-plus-lg me-2"></i> Register Machine
        </button>
    </div>
    
    <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-xxs fw-black text-uppercase tracking-widest text-muted border-bottom">
                        <th class="ps-4 py-3">Machine Code</th>
                        <th class="py-3">Name</th>
                        <th class="py-3">Department</th>
                        <th class="py-3 text-center">Capacity</th>
                        <th class="py-3">Status</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model) {
                        <tr class="border-bottom">
                            <td class="ps-4">
                                <span class="badge bg-slate-100 text-slate-700 border border-slate-200 rounded-2 fw-black text-black px-2 py-1">@m.MachineCode</span>
                            </td>
                            <td class="fw-bold text-slate-800">@m.MachineName</td>
                            <td>
                                <span class="x-small fw-semibold text-muted">@m.Department</span>
                            </td>
                            <td class="text-center fw-black text-slate-700">@m.CapacityPerShift.ToString("N0") <small class="text-muted fw-normal">u/s</small></td>
                            <td>
                                @{
                                    string statusColor = m.Status == "Available" ? "success" : m.Status == "Maintenance" ? "warning" : "danger";
                                }
                                <span class="badge bg-@statusColor bg-opacity-10 text-@statusColor rounded-pill x-small fw-black text-uppercase tracking-widest px-3 py-1">@m.Status</span>
                            </td>
                            <td class="text-end pe-4">
                                <button type="button" class="btn btn-light btn-sm rounded-3" onclick="openEditModal('@m.MachineName', '@m.MachineCode', '@m.Department', '@m.CapacityPerShift')" data-bs-toggle="modal" data-bs-target="#editMachineModal">
                                    <i class="bi bi-pencil-fill text-muted"></i>
                                </button>
                                <a href="@Url.Action("Index", "Dashboard")" class="btn btn-light btn-sm rounded-3 ms-1" title="View Machine Metrics">
                                    <i class="bi bi-graph-up text-muted"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Modals {
<!-- Add Machine Modal -->
<div class="modal fade" id="addMachineModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-bottom-0 p-4 pb-0">
                <h5 class="modal-title fw-black tracking-tight">Register New Machine</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="@Url.Action("AddMachine", "MasterData")" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Machine Name</label>
                        <input type="text" name="MachineName" class="form-control form-control-sm rounded-3" required />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Machine Code</label>
                            <input type="text" name="MachineCode" class="form-control form-control-sm rounded-3" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Department</label>
                            <select name="Department" class="form-select form-select-sm rounded-3" required>
                                <option value="Thermal">Thermal</option>
                                <option value="Flexo">Flexo</option>
                                <option value="PFL">PFL</option>
                                <option value="Heat Transfer">Heat Transfer</option>
                                <option value="RFID">RFID</option>
                                <option value="Offset">Offset</option>
                                <option value="Digital">Digital</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Capacity Per Shift</label>
                        <input type="number" name="CapacityPerShift" class="form-control form-control-sm rounded-3" required />
                    </div>
                </div>
                <div class="modal-footer border-top-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-3 px-4 x-small fw-black text-uppercase tracking-widest" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-rpac-red text-white rounded-3 px-4 x-small fw-black text-uppercase tracking-widest">Register</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Machine Modal -->
<div class="modal fade" id="editMachineModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-bottom-0 p-4 pb-0">
                <h5 class="modal-title fw-black tracking-tight">Edit Machine</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="@Url.Action("Machines", "MasterData")" method="get">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Machine Name</label>
                        <input type="text" id="editMachineName" class="form-control form-control-sm rounded-3" readonly />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Machine Code</label>
                            <input type="text" id="editMachineCode" class="form-control form-control-sm rounded-3" readonly />
                        </div>
                        <div class="col-6">
                            <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Department</label>
                            <input type="text" id="editDepartment" class="form-control form-control-sm rounded-3" readonly />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label x-small fw-black uppercase tracking-widest text-muted">Capacity Per Shift</label>
                        <input type="number" id="editCapacity" class="form-control form-control-sm rounded-3" readonly />
                    </div>
                    <div class="alert alert-warning x-small mb-0 rounded-3 border-0">
                        <i class="bi bi-info-circle me-1"></i> Edit functionality is disabled for this demo user role.
                    </div>
                </div>
                <div class="modal-footer border-top-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-3 px-4 x-small fw-black text-uppercase tracking-widest" data-bs-dismiss="modal">Close</button>
                </div>
            </form>
        </div>
    </div>
</div>
}

<script>
    function openEditModal(name, code, dept, capacity) {
        document.getElementById('editMachineName').value = name;
        document.getElementById('editMachineCode').value = code;
        document.getElementById('editDepartment').value = dept;
        document.getElementById('editCapacity').value = capacity;
    }
</script>
