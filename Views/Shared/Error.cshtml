ViewBag.Title = "System Error";
var code = Request.QueryString["code"] ?? "500";
}

<div class="text-center py-5">
    <div class="display-1 fw-bold text-muted mb-4">@code</div>
    <h3 class="fw-bold">Something went wrong.</h3>
    <p class="text-muted">The system encountered an unexpected error. Please contact the IT administrator.</p>
    <a href="@Url.Action("Index", "Dashboard")" class="btn btn-primary mt-3 px-5 py-2">Return to Dashboard</a>
</div>
